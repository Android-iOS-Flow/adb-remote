# Sao chép file này thành .env và chỉnh sửa.

# Token bắt buộc để truy cập web UI và WebSocket.
# ĐỔI thành chuỗi ngẫu nhiên dài, khó đoán.
AUTH_TOKEN=doi-thanh-chuoi-bi-mat-cua-ban

# Địa chỉ server lắng nghe.
# Mặc định 127.0.0.1 (chỉ localhost) - AN TOÀN khi đi qua SSH/cloudflared tunnel.
# Đặt 0.0.0.0 nếu muốn truy cập trực tiếp trong LAN (kém an toàn hơn).
HOST=127.0.0.1
PORT=8000

# Đường dẫn tới adb. Để trống nếu adb đã có trong PATH.
ADB_PATH=adb

# Đường dẫn tới fastboot (cho tab Terminal). Để trống nếu đã có trong PATH.
FASTBOOT_PATH=fastboot

# Bitrate video (bps). Giảm nếu mạng yếu (vd 4000000 = 4 Mbps).
VIDEO_BITRATE=6000000

# Kích thước video tùy chọn, vd 720x1600. Để trống = độ phân giải gốc thiết bị.
# (Chỉ áp dụng cho engine screenrecord khi UI để Resolution = Original.)
VIDEO_SIZE=

# --- Engine scrcpy (độ trễ thấp + giới hạn FPS) ---
# Phiên bản scrcpy-server sẽ TỰ ĐỘNG TẢI nếu chưa có (vd 2.4, 2.7, 3.1).
# Cũng có thể đổi version ngay trong giao diện web.
SCRCPY_VERSION=2.4

# Tự động tải scrcpy-server từ GitHub release khi cần (1=bật, 0=tắt).
# File tải về nằm trong thư mục vendor/ cạnh server.py.
SCRCPY_AUTO_DOWNLOAD=1

# (Tuỳ chọn) Nếu muốn tự cung cấp file scrcpy-server thay vì auto-download,
# trỏ đường dẫn tuyệt đối tới file ở đây. Khi đặt, SCRCPY_VERSION phải khớp file này.
SCRCPY_SERVER_JAR=

# --- Tính năng Scripts (.bat) ---
# Thư mục chứa các file .bat hiện trong popup "Scripts".
# Để trống = dùng thư mục scripts/ cạnh server.py.
BAT_DIR=

# File manifest liệt kê các .bat tuỳ chỉnh (có thể ở BẤT KỲ ĐÂU trên máy).
# Để trống = dùng scripts/scripts.list. Xem file đó để biết cú pháp.
SCRIPTS_MANIFEST=

# File log ghi lại mọi lệnh stdin gửi xuống script (timestamp + tên script + nội dung).
# Để trống = dùng logs/stdin.log cạnh server.py.
STDIN_LOG=



